# =============================================================================
# AI Pull Request Risk Analyzer — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.

# --- Application ---
APP_NAME=ai-pr-risk-analyzer
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- Database ---
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/pranalyzer
DATABASE_URL_SYNC=postgresql+psycopg2://user:password@localhost:5432/pranalyzer

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- GitHub ---
GITHUB_TOKEN=ghp_your_github_personal_access_token
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=

# --- ML Model ---
MODEL_PATH=./models/codebert-v1
MODEL_NAME=microsoft/codebert-base
MAX_SEQUENCE_LENGTH=512
INFERENCE_DEVICE=cpu

# --- MLflow ---
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=pr-risk-analyzer

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_TIMEOUT=120

# --- Rate Limiting ---
MAX_CONCURRENT_ANALYSES=10
GITHUB_API_RATE_LIMIT=5000

# --- Security ---
API_KEY_HEADER=X-API-Key
API_KEYS=["dev-key-change-me"]
